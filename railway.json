{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "dockerImage": "ghcr.io/aventre-labs/claudeos:latest"
  },
  "deploy": {
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "variables": {
      "CLAUDEOS_AUTH_TOKEN": {
        "description": "Auto-generated auth token for ClaudeOS instance",
        "generator": "secret(32)"
      },
      "CLAUDEOS_DATA_DIR": {
        "description": "Persistent data directory",
        "default": "/data"
      }
    }
  }
}
