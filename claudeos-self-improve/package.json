{
  "name": "claudeos-self-improve",
  "displayName": "ClaudeOS Self-Improve",
  "description": "Self-improvement capabilities for ClaudeOS - extension management via MCP",
  "publisher": "claudeos",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claudeos-extension"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "contributes": {
    "commands": [
      {
        "command": "claudeos.selfImprove.installExtension",
        "title": "Install Extension",
        "category": "ClaudeOS"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.0",
    "esbuild": "^0.27.0",
    "typescript": "~5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.24.0"
  }
}
