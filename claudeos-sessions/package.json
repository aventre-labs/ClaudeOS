{
  "name": "claudeos-sessions",
  "displayName": "ClaudeOS Sessions",
  "description": "Session management sidebar and terminal tabs for ClaudeOS",
  "publisher": "claudeos",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claudeos-extension"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --platform=node --format=cjs --outfile=out/extension.js --external:vscode --external:bufferutil --external:utf-8-validate",
    "watch": "npm run compile -- --watch",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "contributes": {},
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "typescript": "~5.8.0",
    "esbuild": "^0.27.0",
    "@vscode/vsce": "^3.7.0",
    "vitest": "^3.0.0"
  }
}
