{
  "name": "@claudeos/supervisor",
  "version": "0.1.0",
  "description": "ClaudeOS supervisor process - boots code-server, manages sessions, extensions, and secrets",
  "type": "module",
  "main": "dist/supervisor.cjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:dry": "tsx src/index.ts --dry-run",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/supervisor.cjs --external:@fastify/websocket",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
